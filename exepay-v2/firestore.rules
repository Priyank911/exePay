rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read and update their own profile
      allow read: if isOwner(userId);
      allow update: if isOwner(userId);
      
      // Only authenticated users can create their profile
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Prevent deletion
      allow delete: if false;
    }
    
    // Payment requests collection
    match /payment_requests/{paymentId} {
      // Users can read their own payment requests
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Also allow list if query filters by userId
      allow list: if isAuthenticated();
      
      // Users can create payment requests for themselves
      allow create: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.amount > 0
        && request.resource.data.amount <= 100000
        && request.resource.data.status == 'pending';
      
      // Users can update status of their own payments
      // Only allow updating: status, openedAt, completedAt, failedAt, failureReason
      allow update: if isAuthenticated() 
        && resource.data.userId == request.auth.uid;
      
      // Prevent deletion
      allow delete: if false;
    }
    
    // Recent payees collection
    match /recent_payees/{payeeId} {
      // Users can read their own recent payees
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Also allow list if query filters by userId  
      allow list: if isAuthenticated();
      
      // Users can create/update their own recent payees
      allow create, update: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid;
      
      // Prevent deletion
      allow delete: if false;
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
